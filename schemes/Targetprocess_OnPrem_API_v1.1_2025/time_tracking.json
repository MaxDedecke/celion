{
  "category": "Time Tracking",
  "description": "Zeiteinträge und Timesheets.",
  "endpoints": [
    "/api/v1/Times",
    "/api/v1/UserTimes",
    "/api/v1/TimeSheets"
  ],
  "objects": {
    "Time": {
      "id": "int",
      "date": "datetime",
      "spent": "number",
      "user": "User",
      "entity": "WorkItem"
    },
    "UserTime": {
      "id": "int",
      "user": "User",
      "date": "datetime",
      "spent": "number"
    },
    "TimeSheet": {
      "id": "int",
      "startDate": "datetime",
      "endDate": "datetime",
      "user": "User"
    }
  },
  "meta": {
    "base_url_example": "https://{server}/api/v1/",
    "api_version": "v1.1",
    "auth": "Bearer Token oder Basic (username:password)",
    "product_version": "Targetprocess Server 2022.2"
  }
}
{
  "system": "GitLab",
  "apiType": "REST",
  "baseUrlPattern": "gitlab.com/*",
  "authentication": {
    "type": "header",
    "headerName": "PRIVATE-TOKEN",
    "tokenPrefix": "",
    "emailRequired": false,
    "whoami": {
      "endpoint": "/api/v4/user",
      "method": "GET",
      "usernamePath": "name"
    }
  },
  "discovery": {
    "endpoints": {
      "projects": "/api/v4/projects",
      "issues": "/api/v4/issues",
      "users": "/api/v4/users",
      "groups": "/api/v4/groups",
      "mergeRequests": "/api/v4/merge_requests"
    },
    "pagination": {
      "type": "page_per_page",
      "paramPage": "page",
      "paramLimit": "per_page",
      "defaultLimit": 100
    }
  },
  "headers": {
    "accept": "application/json",
    "contentType": "application/json"
  }
}
{
  "category": "Workflow Management",
  "description": "Workflows, Transitionen, sowie Workflow- und IssueType-Schemes.",
  "endpoints": [
    "/rest/api/2/workflow",
    "/rest/api/2/workflowscheme",
    "/rest/api/2/issuetypescheme"
  ],
  "objects": {
    "Workflow": {
      "id": "string",
      "name": "string",
      "description": "string",
      "statuses": "Status[]",
      "transitions": "Transition[]"
    },
    "Transition": {
      "id": "string",
      "name": "string",
      "from": "Status",
      "to": "Status",
      "conditions": "Condition[]",
      "validators": "Validator[]",
      "postFunctions": "PostFunction[]"
    },
    "Condition": {
      "type": "string",
      "config": "object"
    },
    "Validator": {
      "type": "string",
      "config": "object"
    },
    "PostFunction": {
      "type": "string",
      "config": "object"
    },
    "WorkflowScheme": {
      "id": "string",
      "name": "string",
      "mappings": "WorkflowSchemeMapping[]"
    },
    "WorkflowSchemeMapping": {
      "issueTypeId": "string",
      "workflowName": "string"
    },
    "IssueTypeScheme": {
      "id": "string",
      "name": "string",
      "issueTypes": "IssueType[]"
    }
  }
}
{
  "category": "Agile (Jira Software)",
  "description": "Boards, Sprints, Epics und agile Issue-Ansichten (separate API).",
  "endpoints": [
    "/rest/agile/1.0/board",
    "/rest/agile/1.0/board/{boardId}/sprint",
    "/rest/agile/1.0/sprint/{sprintId}",
    "/rest/agile/1.0/epic",
    "/rest/agile/1.0/epic/{epicId}/issue"
  ],
  "objects": {
    "Board": {
      "id": "string",
      "name": "string",
      "type": "string",
      "location": "BoardLocation"
    },
    "BoardLocation": {
      "projectId": "string",
      "projectKey": "string",
      "projectName": "string"
    },
    "Sprint": {
      "id": "string",
      "name": "string",
      "state": "string",
      "startDate": "datetime",
      "endDate": "datetime",
      "completeDate": "datetime",
      "originBoardId": "string",
      "goal": "string"
    },
    "Epic": {
      "id": "string",
      "name": "string",
      "summary": "string"
    },
    "AgileIssue": {
      "id": "string",
      "key": "string",
      "summary": "string",
      "status": "Status",
      "assignee": "User",
      "priority": "Priority"
    }
  }
}
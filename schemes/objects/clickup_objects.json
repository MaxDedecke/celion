{
  "system": "ClickUp",
  "objects": [
    {
      "key": "teams",
      "displayName": "Workspace",
      "endpoint": "/api/v2/team",
      "fields": [
        { "id": "id", "name": "Workspace ID", "type": "text" },
        { "id": "name", "name": "Workspace Name", "type": "text" },
        { "id": "members", "name": "Members", "type": "array" }
      ]
    },
    {
      "key": "spaces",
      "displayName": "Space",
      "endpoint": "/api/v2/team/{team_id}/space",
      "fields": [
        { "id": "id", "name": "Space ID", "type": "text" },
        { "id": "name", "name": "Space Name", "type": "text" },
        { "id": "private", "name": "Is Private", "type": "boolean" },
        { "id": "statuses", "name": "Statuses", "type": "array" }
      ]
    },
    {
      "key": "folders",
      "displayName": "Folder / Ordner",
      "endpoint": "/api/v2/space/{space_id}/folder",
      "fields": [
        { "id": "id", "name": "Folder ID", "type": "text" },
        { "id": "name", "name": "Folder Name", "type": "text" }
      ]
    },
    {
      "key": "lists_in_folders",
      "displayName": "List / Liste (in Folder)",
      "endpoint": "/api/v2/folder/{folder_id}/list",
      "fields": [
        { "id": "id", "name": "List ID", "type": "text" },
        { "id": "name", "name": "List Name", "type": "text" },
        { "id": "content", "name": "Content / Description", "type": "text" },
        { "id": "due_date", "name": "Due Date", "type": "date" }
      ]
    },
    {
      "key": "lists_in_spaces",
      "displayName": "List / Liste (direkt in Space)",

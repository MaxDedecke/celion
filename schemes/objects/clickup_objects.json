      "fields": [
        { "id": "id", "name": "List ID", "type": "text" },
        { "id": "name", "name": "List Name", "type": "text" }
      ]
    },
    {
      "key": "tasks",
      "displayName": "Task / Aufgabe (inkl. Subtasks)",

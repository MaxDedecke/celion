{
  "system": "Azure DevOps",
  "apiType": "REST",
  "baseUrlPattern": "dev.azure.com/*",
  "authentication": {
    "type": "basic",
    "emailRequired": false,
    "whoami": {
      "endpoint": "/_apis/profile/profiles/me?api-version=6.0",
      "method": "GET",
      "usernamePath": "displayName"
    }
  },
  "discovery": {
    "endpoints": {
      "projects": "/_apis/projects?api-version=7.1-preview.1",
      "workItems": "/_apis/wit/workitems?ids={ids}&api-version=7.1-preview.1",
      "workItemTypes": "/_apis/wit/workitemtypes?api-version=7.1-preview.1",
      "repos": "/_apis/git/repositories?api-version=7.1-preview.1",
      "pipelines": "/_apis/pipelines?api-version=7.1-preview.1",
      "users": "/_apis/graph/users?api-version=7.1-preview.1"
    },
    "pagination": {
      "type": "continuationToken",
      "headerContinuation": "x-ms-continuationtoken",
      "paramLimit": "$top",
      "defaultLimit": 100
    }
  },
  "headers": {
    "accept": "application/json",
    "contentType": "application/json"
  }
}
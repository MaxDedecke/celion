{
  "system": "Asana",
  "apiType": "REST",
  "baseUrlPattern": "*.asana.com",
  "apiBaseUrl": "https://app.asana.com",
  "authentication": {
    "type": "bearer",
    "tokenPrefix": "Bearer ",
    "emailRequired": false,
    "whoami": {
      "endpoint": "/api/1.0/users/me",
      "method": "GET",
      "usernamePath": "data.name"
    }
  },
  "discovery": {
    "endpoints": {
      "projects": "/api/1.0/projects",
      "tasks": "/api/1.0/tasks",
      "users": "/api/1.0/users"
    },
    "pagination": {
      "type": "offset",
      "paramStart": "offset",
      "paramLimit": "limit",
      "defaultLimit": 50
    }
  },
  "headers": {
    "contentType": "application/json",
    "accept": "application/json"
  }
}

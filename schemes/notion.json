{
  "system": "Notion",
  "apiType": "REST",
  "baseUrlPattern": "*.notion.so",
  "apiBaseUrl": "https://api.notion.com",
  "authentication": {
    "type": "bearer",
    "tokenPrefix": "Bearer ",
    "emailRequired": false,
    "whoami": {
      "endpoint": "/v1/users/me",
      "method": "GET"
    }
  },
  "discovery": {
    "endpoints": {
      "search": "/v1/search",
      "databasesList": "/v1/databases",
      "databaseRetrieve": "/v1/databases/{database_id}",
      "databaseQuery": "/v1/databases/{database_id}/query",
      "pages": "/v1/pages",
      "pageRetrieve": "/v1/pages/{page_id}",
      "blocks": "/v1/blocks/{block_id}/children",
      "comments": "/v1/comments",
      "users": "/v1/users"
    },
    "pagination": {
      "type": "cursor",
      "paramCursor": "start_cursor",
      "paramLimit": "page_size",
      "defaultLimit": 100
    }
  },
  "headers": {
    "Accept": "application/json",
    "Content-Type": "application/json",
    "Notion-Version": "2022-06-28"
  },
  "agentInstructions": "[REQ-1: Use 'search' for workspace-wide database discovery]. [REQ-2: Deep Probe: For found databases, call 'databaseRetrieve' to analyze custom properties/fields]. [REQ-3: For comments, ALWAYS append the query parameter manually. Example: /v1/comments?block_id={id}]. [REQ-4: Count users via 'users' endpoint]."
}
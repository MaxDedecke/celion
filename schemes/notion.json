{
  "system": "Notion",
  "apiType": "REST",
  "baseUrlPattern": "*.notion.so",
  "apiBaseUrl": "https://api.notion.com",
  "authentication": {
    "type": "bearer",
    "tokenPrefix": "Bearer ",
    "emailRequired": false,
    "whoami": {
      "endpoint": "/v1/users/me",
      "method": "GET"
    }
  },
  "discovery": {
    "endpoints": {
      "search": "/v1/search",
      "databasesList": "/v1/databases",
      "databaseQuery": "/v1/databases/{database_id}/query",
      "pages": "/v1/pages",
      "blocks": "/v1/blocks/{block_id}/children",
      "users": "/v1/users"
    },
    "pagination": {
      "type": "cursor",
      "paramCursor": "start_cursor",
      "paramLimit": "page_size",
      "defaultLimit": 100
    }
  },
  "headers": {
    "Accept": "application/json",
    "Content-Type": "application/json",
    "Notion-Version": "2022-06-28"
  }
}
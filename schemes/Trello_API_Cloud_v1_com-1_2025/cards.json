{
  "category": "Cards",
  "description": "Aufgaben oder Tickets auf einem Board.",
  "endpoints": [
    "/cards",
    "/cards/{id}",
    "/cards/{id}/checklists",
    "/cards/{id}/attachments",
    "/cards/{id}/actions",
    "/cards/{id}/members",
    "/cards/{id}/labels",
    "/webhooks",
    "/webhooks/{id}",
    "/notifications",
    "/notifications/{id}",
    "/search",
    "/search/members",
    "/enterprises",
    "/enterprises/{id}",
    "/enterprises/{id}/members",
    "/plugins",
    "/plugins/{id}",
    "/boardPlugins",
    "/batch",
    "/stickers",
    "/emoji"
  ],
  "objects": {
    "Card": {
      "id": "string",
      "name": "string",
      "desc": "string",
      "idList": "string",
      "idBoard": "string",
      "idMembers": "string[]",
      "idLabels": "string[]",
      "due": "datetime",
      "dueComplete": "boolean",
      "closed": "boolean",
      "pos": "number",
      "attachments": "Attachment[]",
      "checklists": "Checklist[]",
      "actions": "Action[]"
    },
    "Action": {
      "id": "string",
      "type": "string",
      "date": "datetime",
      "idMemberCreator": "string",
      "data": "object"
    },
    "Attachment": {
      "id": "string",
      "bytes": "number",
      "date": "datetime",
      "name": "string",
      "url": "string",
      "edgeColor": "string"
    },
    "Webhook": {
      "id": "string",
      "description": "string",
      "idModel": "string",
      "callbackURL": "string",
      "active": "boolean",
      "createdAt": "datetime"
    },
    "Notification": {
      "id": "string",
      "type": "string",
      "date": "datetime",
      "unread": "boolean",
      "memberCreator": "Member",
      "data": "object"
    },
    "SearchResult": {
      "id": "string",
      "type": "string",
      "name": "string",
      "url": "string",
      "idBoard": "string",
      "idList": "string"
    },
    "Enterprise": {
      "id": "string",
      "name": "string",
      "displayName": "string",
      "idBoards": "string[]",
      "members": "Member[]"
    },
    "Plugin": {
      "id": "string",
      "name": "string",
      "url": "string",
      "public": "boolean",
      "scope": "string"
    },
    "BatchRequest": {
      "requests": "object[]",
      "responses": "object[]"
    },
    "Sticker": {
      "id": "string",
      "imageUrl": "string",
      "top": "number",
      "left": "number",
      "zIndex": "number"
    },
    "Emoji": {
      "name": "string",
      "unicode": "string"
    }
  }
}
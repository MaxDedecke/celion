{
  "category": "Custom Fields",
  "description": "Power-Up Custom Fields für Cards.",
  "endpoints": [
    "/customFields/{id}",
    "/cards/{id}/customFieldItems",
    "/webhooks",
    "/webhooks/{id}",
    "/notifications",
    "/notifications/{id}",
    "/search",
    "/search/members",
    "/enterprises",
    "/enterprises/{id}",
    "/enterprises/{id}/members",
    "/plugins",
    "/plugins/{id}",
    "/boardPlugins",
    "/batch",
    "/stickers",
    "/emoji"
  ],
  "objects": {
    "CustomField": {
      "id": "string",
      "name": "string",
      "type": "string",
      "options": "CustomFieldOption[]"
    },
    "CustomFieldOption": {
      "id": "string",
      "value": "string | number | boolean",
      "color": "string"
    },
    "CustomFieldItem": {
      "id": "string",
      "idCustomField": "string",
      "idModel": "string",
      "value": "string | number | boolean"
    },
    "Webhook": {
      "id": "string",
      "description": "string",
      "idModel": "string",
      "callbackURL": "string",
      "active": "boolean",
      "createdAt": "datetime"
    },
    "Notification": {
      "id": "string",
      "type": "string",
      "date": "datetime",
      "unread": "boolean",
      "memberCreator": "Member",
      "data": "object"
    },
    "SearchResult": {
      "id": "string",
      "type": "string",
      "name": "string",
      "url": "string",
      "idBoard": "string",
      "idList": "string"
    },
    "Enterprise": {
      "id": "string",
      "name": "string",
      "displayName": "string",
      "idBoards": "string[]",
      "members": "Member[]"
    },
    "Plugin": {
      "id": "string",
      "name": "string",
      "url": "string",
      "public": "boolean",
      "scope": "string"
    },
    "BatchRequest": {
      "requests": "object[]",
      "responses": "object[]"
    },
    "Sticker": {
      "id": "string",
      "imageUrl": "string",
      "top": "number",
      "left": "number",
      "zIndex": "number"
    },
    "Emoji": {
      "name": "string",
      "unicode": "string"
    }
  }
}
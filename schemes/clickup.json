{
  "system": "ClickUp",
  "apiType": "REST",
  "baseUrlPattern": "api.clickup.com",
  "auth": {
    "type": "bearer_token",
    "headerTemplate": "Authorization: Bearer <TOKEN>",
    "requiresApiToken": true,
    "requiresEmail": false,
    "probeEndpoint": "/api/v2/user",
    "successStatus": 200
  },
  "discovery": {
    "endpoints": {
      "teams": "/api/v2/team",
      "spaces": "/api/v2/team/{team_id}/space",
      "folders": "/api/v2/space/{space_id}/folder",
      "lists": "/api/v2/folder/{folder_id}/list",
      "tasks": "/api/v2/list/{list_id}/task",
      "users": "/api/v2/team/{team_id}/user"
    },
    "pagination": {
      "type": "page_limit",
      "paramPage": "page",
      "paramLimit": "limit",
      "defaultLimit": 100
    }
  },
  "headers": {
    "accept": "application/json",
    "contentType": "application/json"
  }
}
{
  "system": "Jira Cloud",
  "apiType": "REST",
  "baseUrlPattern": "*.atlassian.net",
  "authentication": {
    "type": "basic",
    "emailRequired": true,
    "whoami": {
      "endpoint": "/rest/api/3/myself",
      "method": "GET",
      "usernamePath": "displayName"
    }
  },
  "discovery": {
    "endpoints": {
      "projects": "/rest/api/3/project",
      "issues": "/rest/api/3/search",
      "users": "/rest/api/3/users/search",
      "workflows": "/rest/api/3/workflow"
    },
    "pagination": {
      "type": "startAt_maxResults",
      "paramStart": "startAt",
      "paramLimit": "maxResults",
      "defaultLimit": 50
    }
  },
  "headers": {
    "accept": "application/json",
    "contentType": "application/json"
  }
}

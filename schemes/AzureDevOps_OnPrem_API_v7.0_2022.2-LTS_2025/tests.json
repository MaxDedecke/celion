{
  "category": "Test Management",
  "description": "Testpläne, Testsuites, Testcases und Testergebnisse.",
  "endpoints": [
    "/_apis/test/plans",
    "/_apis/test/suites",
    "/_apis/test/cases",
    "/_apis/test/runs",
    "/_apis/test/results"
  ],
  "objects": {
    "TestPlan": {
      "id": "int",
      "name": "string",
      "area": "string",
      "iteration": "string"
    },
    "TestSuite": {
      "id": "int",
      "name": "string",
      "planId": "int",
      "testCases": "TestCase[]"
    },
    "TestCase": {
      "id": "int",
      "title": "string",
      "priority": "int",
      "assignedTo": "User"
    },
    "TestRun": {
      "id": "int",
      "name": "string",
      "state": "string",
      "automated": "boolean"
    },
    "TestResult": {
      "id": "int",
      "outcome": "string",
      "durationInMs": "int"
    }
  },
  "meta": {
    "base_url_example": "https://{server}/tfs/{collection}/_apis/",
    "api_version": "7.0",
    "auth": "Basic (username: '', password: <PAT>) or Windows Auth depending on setup"
  }
}